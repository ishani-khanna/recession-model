# Copy this file to .env and fill in real values (.env is git-ignored).
# These names match the GDP Tracker project so the same credentials work here.

# FRED (St. Louis Fed) REST API key — https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# Moody's Analytics DataBuffet — two-key scheme (access key + encryption key)
DATABUFFET_ACC_KEY=
DATABUFFET_ENC_KEY=
